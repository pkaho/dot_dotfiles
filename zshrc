# ==============================================
# Zsh 主配置入口 - 仅负责按顺序加载细分配置 & 框架初始化
# 配置拆分目录: ~/.zsh/
# ==============================================
# 加载配置(按数字顺序)
for file in ~/.zsh/[0-9]*.zsh; do
    [[ -f "$file" ]] && source "$file"
done

# =============================================================================
# 第三方工具初始化
# =============================================================================
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
source <(fzf --zsh)

